<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shelby Network — Ecosystem</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #030712;
    --surface: #0b1120;
    --surface2: #111827;
    --border: rgba(99,210,255,0.1);
    --border-bright: rgba(99,210,255,0.3);
    --cyan: #63d2ff;
    --cyan-dim: rgba(99,210,255,0.15);
    --teal: #00ffcc;
    --teal-dim: rgba(0,255,204,0.1);
    --gold: #ffd166;
    --text: #e2f0ff;
    --text-muted: #5b7a99;
    --glow: 0 0 30px rgba(99,210,255,0.15);
    --glow-strong: 0 0 60px rgba(99,210,255,0.25);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR */
  .cursor {
    position: fixed; width: 10px; height: 10px;
    background: var(--cyan); border-radius: 50%;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform 0.1s, background 0.2s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    position: fixed; width: 34px; height: 34px;
    border: 1px solid rgba(99,210,255,0.5); border-radius: 50%;
    pointer-events: none; z-index: 9998;
    transform: translate(-50%,-50%);
    transition: transform 0.18s ease, width 0.2s, height 0.2s, border-color 0.2s;
  }
  body:has(a:hover) .cursor-ring,
  body:has(button:hover) .cursor-ring {
    width: 50px; height: 50px;
    border-color: var(--cyan);
  }

  /* BACKGROUND GRID */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(99,210,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,210,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none; z-index: 0;
  }

  /* SCANLINE */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.07) 2px,
      rgba(0,0,0,0.07) 4px
    );
    pointer-events: none; z-index: 0;
  }

  /* AMBIENT GLOW ORBS */
  .orb {
    position: fixed; border-radius: 50%;
    filter: blur(120px); pointer-events: none; z-index: 0;
    opacity: 0.35;
    animation: orb-drift 20s ease-in-out infinite alternate;
  }
  .orb-1 { width: 600px; height: 600px; top: -200px; left: -150px; background: radial-gradient(circle, rgba(99,210,255,0.5), transparent 70%); }
  .orb-2 { width: 500px; height: 500px; top: 40%; right: -180px; background: radial-gradient(circle, rgba(0,255,204,0.4), transparent 70%); animation-delay: -8s; }
  .orb-3 { width: 400px; height: 400px; bottom: 5%; left: 20%; background: radial-gradient(circle, rgba(99,80,255,0.3), transparent 70%); animation-delay: -14s; }

  @keyframes orb-drift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -40px) scale(1.05); }
    100% { transform: translate(-20px, 30px) scale(0.95); }
  }

  /* ---- HEADER ---- */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 5vw;
    height: 68px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(3,7,18,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex; align-items: center; gap: 12px;
    text-decoration: none; color: var(--text);
    flex-shrink: 0;
  }
  .logo-img {
    height: 40px;
    width: 40px;
    border-radius: 8px;
    object-fit: cover;
    display: block;
    transition: box-shadow 0.3s, transform 0.2s;
    flex-shrink: 0;
  }
  .logo:hover .logo-img {
    box-shadow: 0 0 18px rgba(99,210,255,0.35);
    transform: scale(1.05);
  }
  .logo-wordmark {
    font-size: 1.1rem; font-weight: 800; letter-spacing: 0.06em;
    text-transform: uppercase; white-space: nowrap;
    line-height: 1;
  }
  .logo-dot { color: var(--cyan); }
  .logo-icon {
    width: 32px; height: 32px;
    position: relative;
  }
  .logo-icon svg { width: 100%; height: 100%; }
  .logo span { color: var(--cyan); }

  nav { display: flex; gap: 2rem; align-items: center; }
  nav a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none;
    position: relative; padding-bottom: 2px;
    transition: color 0.2s;
  }
  nav a::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1px; background: var(--cyan);
    transition: width 0.3s;
  }
  nav a:hover { color: var(--cyan); }
  nav a:hover::after { width: 100%; }
  nav a.active { color: var(--cyan); }
  nav a.active::after { width: 100%; }

  /* ---- NAV DROPDOWN ---- */
  .nav-dropdown-wrap {
    position: relative;
    display: flex; align-items: center;
  }

  .nav-dropdown-trigger {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted);
    background: none; border: none;
    display: flex; align-items: center; gap: 5px;
    cursor: none; padding: 0; padding-bottom: 2px;
    position: relative;
    transition: color 0.2s;
  }
  .nav-dropdown-trigger::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1px; background: var(--cyan);
    transition: width 0.3s;
  }
  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger.open {
    color: var(--cyan);
  }
  .nav-dropdown-trigger:hover::after,
  .nav-dropdown-trigger.open::after { width: 100%; }

  .dropdown-chevron {
    transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
    flex-shrink: 0;
  }
  .nav-dropdown-trigger.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* THE MENU */
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    width: 290px;
    background: rgba(8, 14, 28, 0.96);
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    padding: 6px;
    box-shadow:
      0 0 0 1px rgba(99,210,255,0.06),
      0 20px 60px rgba(0,0,0,0.6),
      0 0 40px rgba(99,210,255,0.08);
    backdrop-filter: blur(24px);
    z-index: 200;
    /* hidden state */
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px) scale(0.97);
    transform-origin: top center;
    transition:
      opacity 0.22s cubic-bezier(0.4,0,0.2,1),
      transform 0.22s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-dropdown-menu.open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  /* top cyan accent line */
  .dropdown-glow-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--teal), transparent);
    border-radius: 1px;
    margin: 0 6px 6px;
    opacity: 0.6;
  }

  /* connecting bridge so mouse can travel from trigger to menu */
  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -18px; left: 0; right: 0;
    height: 18px;
  }

  .dropdown-item {
    display: flex; align-items: center; gap: 11px;
    padding: 10px 12px;
    border-radius: 7px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.18s, box-shadow 0.18s;
    cursor: none;
    position: relative;
    overflow: hidden;
  }
  .dropdown-item::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(99,210,255,0.07), transparent);
    opacity: 0; transition: opacity 0.18s;
    border-radius: 7px;
  }
  .dropdown-item:not(.dropdown-item--disabled):hover {
    background: rgba(99,210,255,0.07);
    box-shadow: inset 0 0 0 1px rgba(99,210,255,0.12);
  }
  .dropdown-item:not(.dropdown-item--disabled):hover::before { opacity: 1; }

  .dropdown-item--disabled {
    opacity: 0.38;
    cursor: not-allowed;
    pointer-events: none;
  }

  .dropdown-item-icon {
    width: 32px; height: 32px; flex-shrink: 0;
    border: 1px solid rgba(99,210,255,0.18);
    border-radius: 6px;
    background: rgba(99,210,255,0.05);
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.18s, background 0.18s;
  }
  .dropdown-item-icon svg { width: 14px; height: 14px; color: var(--cyan); }
  .dropdown-item:not(.dropdown-item--disabled):hover .dropdown-item-icon {
    border-color: rgba(99,210,255,0.45);
    background: rgba(99,210,255,0.12);
  }

  .dropdown-item-text {
    display: flex; flex-direction: column; gap: 2px;
    flex: 1; min-width: 0;
  }
  .dropdown-item-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em;
    color: var(--text); line-height: 1.2;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .dropdown-item-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem; letter-spacing: 0.04em;
    color: var(--text-muted); line-height: 1.4;
  }

  /* badges */
  .dropdown-item-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem; font-weight: 600; letter-spacing: 0.12em;
    padding: 3px 7px; border-radius: 4px;
    flex-shrink: 0; text-transform: uppercase;
  }
  .badge-dev {
    background: rgba(99,210,255,0.12);
    color: var(--cyan);
    border: 1px solid rgba(99,210,255,0.25);
  }
  .badge-test {
    background: rgba(0,255,204,0.1);
    color: var(--teal);
    border: 1px solid rgba(0,255,204,0.25);
  }
  .badge-soon {
    background: rgba(255,100,80,0.1);
    color: #ff8c7a;
    border: 1px solid rgba(255,100,80,0.2);
    animation: pulse-soon 2.4s ease-in-out infinite;
  }
  @keyframes pulse-soon {
    0%,100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .dropdown-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-bright), transparent);
    margin: 4px 8px;
  }

  .nav-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--bg); background: var(--cyan);
    border: none; padding: 8px 18px; border-radius: 3px;
    cursor: none; font-weight: 500;
    transition: box-shadow 0.3s, background 0.2s;
    text-decoration: none;
  }
  .nav-cta:hover { background: #fff; box-shadow: 0 0 20px rgba(99,210,255,0.6); }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: none; }
  .hamburger span { display: block; width: 24px; height: 1.5px; background: var(--text); transition: 0.3s; }

  /* ---- HERO ---- */
  .hero {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 120px 5vw 80px;
  }

  .hero-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid var(--border-bright);
    padding: 6px 16px; border-radius: 2px;
    margin-bottom: 2rem;
    animation: fade-up 0.8s ease both;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .hero-tag::before {
    content: ''; display: inline-block; width: 6px; height: 6px;
    background: var(--cyan); border-radius: 50%;
    animation: pulse-dot 1.5s infinite;
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.6); }
  }

  h1 {
    font-size: clamp(2.6rem, 6vw, 5.5rem);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.02em;
    animation: fade-up 0.9s 0.1s ease both;
  }
  h1 .gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--teal) 50%, #a78bfa 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin-top: 1.5rem;
    max-width: 560px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem; line-height: 1.8;
    color: var(--text-muted);
    animation: fade-up 1s 0.2s ease both;
  }

  .hero-actions {
    margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
    animation: fade-up 1s 0.3s ease both;
  }
  .btn-primary, .btn-ghost {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 13px 28px; border-radius: 3px;
    cursor: none; transition: all 0.25s; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary {
    background: var(--cyan); color: var(--bg); border: 1px solid var(--cyan);
    font-weight: 600;
  }
  .btn-primary:hover { background: transparent; color: var(--cyan); box-shadow: 0 0 30px rgba(99,210,255,0.3); }
  .btn-ghost {
    background: transparent; color: var(--text); border: 1px solid var(--border-bright);
  }
  .btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); }

  /* HERO NETWORK VISUAL */
  .hero-visual {
    margin-top: 4rem; width: 100%; max-width: 700px;
    animation: fade-up 1s 0.5s ease both;
  }
  .hero-visual canvas { width: 100%; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- SECTION COMMON ---- */
  section { position: relative; z-index: 1; }
  .section-header {
    text-align: center; margin-bottom: 4rem;
  }
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 1rem;
    display: block;
  }
  .section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800; letter-spacing: -0.02em;
  }
  .section-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem; color: var(--text-muted);
    margin-top: 0.75rem; line-height: 1.7;
  }

  /* ---- ECOSYSTEM GRID ---- */
  .ecosystem { padding: 100px 5vw; }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5px;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--border);
  }

  .module-card {
    background: var(--surface);
    padding: 2.2rem;
    position: relative; overflow: hidden;
    transition: background 0.3s;
    cursor: none;
  }
  .module-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--cyan-dim), transparent 60%);
    opacity: 0; transition: opacity 0.4s;
  }
  .module-card:hover { background: var(--surface2); }
  .module-card:hover::before { opacity: 1; }

  /* corner accent */
  .module-card::after {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0 32px 32px 0;
    border-color: transparent var(--border-bright) transparent transparent;
    transition: border-color 0.3s;
  }
  .module-card:hover::after { border-color: transparent var(--cyan) transparent transparent; }

  .card-icon {
    width: 46px; height: 46px;
    border: 1px solid var(--border-bright);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.4rem;
    background: rgba(99,210,255,0.04);
    transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
    position: relative; z-index: 1;
  }
  .module-card:hover .card-icon {
    border-color: var(--cyan);
    background: rgba(99,210,255,0.1);
    box-shadow: 0 0 20px rgba(99,210,255,0.2);
  }
  .card-icon svg { width: 22px; height: 22px; }

  .card-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.2em;
    color: var(--text-muted);
    position: absolute; top: 1.5rem; right: 1.8rem;
    z-index: 1;
  }

  .card-title {
    font-size: 1.05rem; font-weight: 700; letter-spacing: 0.02em;
    margin-bottom: 0.6rem;
    position: relative; z-index: 1;
    transition: color 0.3s;
  }
  .module-card:hover .card-title { color: var(--cyan); }

  .card-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem; line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 1.6rem;
    position: relative; z-index: 1;
  }

  .card-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--cyan); background: transparent;
    border: 1px solid var(--border-bright);
    padding: 7px 16px; border-radius: 2px;
    cursor: none; transition: all 0.25s;
    display: inline-flex; align-items: center; gap: 6px;
    position: relative; z-index: 1;
  }
  .card-btn:hover { background: var(--cyan); color: var(--bg); box-shadow: 0 0 16px rgba(99,210,255,0.4); }
  .card-btn .arrow { transition: transform 0.2s; }
  .card-btn:hover .arrow { transform: translateX(4px); }

  /* ---- STATS ---- */
  .stats { padding: 80px 5vw; }

  .stats-wrap {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    padding: 3.5rem 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    position: relative; overflow: hidden;
  }
  .stats-wrap::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,210,255,0.07), transparent 70%);
  }

  .stat-item {
    padding: 1.5rem 2rem;
    border-right: 1px solid var(--border);
    position: relative; z-index: 1;
    text-align: center;
    transition: background 0.3s;
  }
  .stat-item:last-child { border-right: none; }
  .stat-item:hover { background: rgba(99,210,255,0.04); }

  .stat-icon {
    width: 36px; height: 36px;
    margin: 0 auto 1rem;
    border: 1px solid var(--border-bright);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .stat-icon svg { width: 16px; height: 16px; }

  .stat-num {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800; letter-spacing: -0.02em;
    color: var(--cyan);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); margin-top: 0.5rem;
  }
  .stat-bar {
    width: 60%; height: 2px; background: var(--border);
    margin: 1rem auto 0;
    border-radius: 2px; overflow: hidden;
  }
  .stat-bar-fill {
    height: 100%; background: linear-gradient(90deg, var(--cyan), var(--teal));
    border-radius: 2px; transform: scaleX(0); transform-origin: left;
    transition: transform 1.2s cubic-bezier(0.23,1,0.32,1);
  }
  .stat-bar-fill.animated { transform: scaleX(1); }

  .stat-sublabel {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.12em;
    color: rgba(91,122,153,0.7); margin-top: 3px;
    text-transform: uppercase;
  }

  .net-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem; padding: 7px 14px;
    border: 1px solid var(--border-bright);
    border-radius: 3px; background: rgba(99,210,255,0.04);
  }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--cyan); animation: pulse-dot 1.8s infinite; }
  .badge-name { color: var(--text); font-weight: 600; }
  .badge-note { color: var(--text-muted); font-size: 0.65rem; }

  .stack-row { }
  .stack-item { display: flex; flex-direction: column; gap: 3px; align-items: center; text-align: center; }
  .stack-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .stack-val {
    font-size: 0.82rem; font-weight: 600; color: var(--text);
  }
  .stack-divider {
    width: 1px; height: 36px; background: var(--border);
    align-self: center;
  }

  @media (max-width: 768px) {
    .stack-divider { display: none; }
    .stack-row { flex-direction: column; align-items: flex-start; }
    .stack-item { align-items: flex-start; text-align: left; }
  }

  /* ---- FOOTER ---- */
  footer {
    position: relative; z-index: 1;
    padding: 3rem 5vw 2rem;
    border-top: 1px solid var(--border);
    display: flex; flex-wrap: wrap; gap: 1.5rem;
    align-items: center; justify-content: space-between;
  }

  .footer-left {
    display: flex; align-items: center; gap: 12px;
    flex-wrap: wrap;
  }
  .footer-logo-img {
    height: 38px;
    width: 38px;
    border-radius: 7px;
    object-fit: cover;
    flex-shrink: 0;
    display: block;
    transition: box-shadow 0.3s, transform 0.2s;
  }
  .footer-logo-img:hover {
    box-shadow: 0 0 14px rgba(99,210,255,0.3);
    transform: scale(1.05);
  }
  .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.05em;
  }

  .footer-links {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
  }
  .footer-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); text-decoration: none;
    transition: color 0.2s;
    display: flex; align-items: center; gap: 5px;
  }
  .footer-links a:hover { color: var(--cyan); }

  /* ---- NETWORK TICKER ---- */
  .ticker {
    position: relative; z-index: 1;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 10px 0;
    background: rgba(11,17,32,0.7);
  }
  .ticker-inner {
    display: flex; gap: 3rem;
    white-space: nowrap;
    animation: ticker-scroll 28s linear infinite;
  }
  .ticker-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--text-muted);
    display: flex; align-items: center; gap: 8px;
    flex-shrink: 0;
  }
  .ticker-item .dot { width: 5px; height: 5px; background: var(--cyan); border-radius: 50%; }
  .ticker-item .up { color: var(--teal); }
  .ticker-item .down { color: #ff6b8a; }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 768px) {
    nav { display: none; }
    .hamburger { display: flex; }
    .modules-grid { grid-template-columns: 1fr; }
    .stats-wrap {
      grid-template-columns: 1fr 1fr;
    }
    .stat-item { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .stat-item:nth-child(2n) { border-right: none; }
    .stat-item:nth-last-child(-n+2) { border-bottom: none; }
    footer { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .footer-left { flex-direction: row; align-items: center; flex-wrap: wrap; gap: 10px; }
    .hero-actions { flex-direction: column; align-items: center; }
  }

  @media (max-width: 480px) {
    .stats-wrap { grid-template-columns: 1fr; padding: 2rem 1.5rem; }
    .stat-item { border-right: none; border-bottom: 1px solid var(--border); }
    .stat-item:last-child { border-bottom: none; }
  }

  /* ---- SCROLL FADE ---- */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<!-- HEADER -->
<header>
  <a href="https://shelby.xyz" target="_blank" rel="noopener noreferrer" class="logo">
    <img src="data:image/jpeg;base64,"
         alt="Shelby Network"
         class="logo-img"
         width="40"
         height="40"
    />
    <span class="logo-wordmark">Shelby<span class="logo-dot">.</span>Network</span>
  </a>
  <nav>
    <a href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">Home</a>
    <a href="#ecosystem" class="active">Ecosystem</a>

    <!-- NETWORK DROPDOWN -->
    <div class="nav-dropdown-wrap" id="networkDropdown">
      <button class="nav-dropdown-trigger" id="networkTrigger" aria-haspopup="true" aria-expanded="false">
        Network
        <svg class="dropdown-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="nav-dropdown-menu" id="networkMenu" role="menu">
        <!-- top glow line -->
        <div class="dropdown-glow-line"></div>

        <a href="https://api.shelbynet.shelby.xyz/shelby" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">ShelbyNet Devnet</span>
            <span class="dropdown-item-desc">Development network for testing features</span>
          </div>
          <span class="dropdown-item-badge badge-dev">DEV</span>
        </a>

        <a href="https://api.testnet.aptoslabs.com/v1" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <polygon points="8,2 14,5.5 14,10.5 8,14 2,10.5 2,5.5"/>
              <circle cx="8" cy="8" r="2"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">ShelbyNet Testnet</span>
            <span class="dropdown-item-desc">Public testing environment</span>
          </div>
          <span class="dropdown-item-badge badge-test">TEST</span>
        </a>

        <div class="dropdown-divider"></div>

        <div class="dropdown-item dropdown-item--disabled" role="menuitem" aria-disabled="true">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M8 1l2.5 5 5.5.8-4 3.9.9 5.5L8 13.5 3.1 16.2l1-5.5L.1 6.8 5.5 6z"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">ShelbyNet Mainnet</span>
            <span class="dropdown-item-desc">Production-grade global network</span>
          </div>
          <span class="dropdown-item-badge badge-soon">Soon</span>
        </div>

      </div>
    </div>

    <!-- DEVELOPERS DROPDOWN -->
    <div class="nav-dropdown-wrap" id="devDropdown">
      <button class="nav-dropdown-trigger" id="devTrigger" aria-haspopup="true" aria-expanded="false">
        Developers
        <svg class="dropdown-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="nav-dropdown-menu" id="devMenu" role="menu">
        <div class="dropdown-glow-line"></div>

        <a href="https://docs.shelby.xyz/protocol" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M3 2h7l3 3v9H3z"/><path d="M10 2v3h3"/><path d="M5 7h6M5 10h4"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">Documentation</span>
            <span class="dropdown-item-desc">Guides, concepts and protocol reference</span>
          </div>
        </a>

        <a href="https://docs.shelby.xyz/sdks/typescript" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <polyline points="5,4 2,8 5,12"/><polyline points="11,4 14,8 11,12"/><line x1="9" y1="3" x2="7" y2="13"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">SDK</span>
            <span class="dropdown-item-desc">TypeScript &amp; React SDK for Shelby Protocol</span>
          </div>
          <span class="dropdown-item-badge badge-dev">TS</span>
        </a>

        <a href="https://docs.shelby.xyz/api" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <rect x="1" y="3" width="14" height="10" rx="1.5"/><path d="M4 8h8M10 6l2 2-2 2"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">API Reference</span>
            <span class="dropdown-item-desc">REST endpoints and RPC methods</span>
          </div>
        </a>

        <div class="dropdown-divider"></div>

        <a href="https://github.com/shelby" target="_blank" class="dropdown-item" role="menuitem">
          <div class="dropdown-item-icon">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M8 1.5a6.5 6.5 0 0 0-2.056 12.67c.325.06.445-.14.445-.31v-1.09c-1.806.393-2.187-.872-2.187-.872-.295-.75-.72-.95-.72-.95-.59-.403.044-.395.044-.395.652.046 1 .67 1 .67.58 1 1.523.71 1.894.543.059-.422.227-.71.413-.873-1.442-.164-2.957-.72-2.957-3.207 0-.708.253-1.287.668-1.74-.067-.165-.29-.824.063-1.717 0 0 .545-.175 1.785.665A6.22 6.22 0 0 1 8 5.88c.551.003 1.107.075 1.625.22 1.238-.84 1.782-.665 1.782-.665.354.893.131 1.552.064 1.716.416.454.667 1.033.667 1.741 0 2.494-1.517 3.041-2.963 3.202.233.2.44.598.44 1.205v1.786c0 .172.118.374.448.31A6.5 6.5 0 0 0 8 1.5z"/>
            </svg>
          </div>
          <div class="dropdown-item-text">
            <span class="dropdown-item-name">GitHub</span>
            <span class="dropdown-item-desc">Open source repos and code examples</span>
          </div>
        </a>

      </div>
    </div>
    <a href="https://discord.com/invite/shelbyserves" target="_blank" rel="noopener noreferrer">Community</a>
    <a href="#" class="nav-cta">Launch App</a>
  </nav>
  <div class="hamburger" id="hamburger">
    <span></span><span></span><span></span>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-tag">Early Access — shelbynet + testnet Live</div>
  <h1>Shelby Network<br><span class="gradient">Ecosystem</span></h1>
  <p class="hero-sub">High-performance decentralized blob storage built for video streaming, AI inference, and large-scale data — powered by Aptos and Jump Trading infrastructure.</p>
  <div class="hero-actions">
    <a href="#ecosystem" class="btn-primary">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12l4 4 4-4"/></svg>
      Explore Modules
    </a>
    <a href="https://github.com/shelby" target="_blank" rel="noopener noreferrer" class="btn-ghost">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      View on GitHub
    </a>
  </div>
  <div class="hero-visual">
    <canvas id="networkCanvas" height="200"></canvas>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-inner" id="ticker">
    <div class="ticker-item"><span class="dot"></span> Network <span class="up">shelbynet + testnet</span></div>
    <div class="ticker-item"><span class="dot"></span> Storage Providers <span class="up">16 active</span></div>
    <div class="ticker-item"><span class="dot"></span> Storage Capacity <span>~10 TiB</span></div>
    <div class="ticker-item"><span class="dot"></span> Aptos TPS <span class="up">30,000</span></div>
    <div class="ticker-item"><span class="dot"></span> Settlement Layer <span>Aptos Blockchain</span></div>
    <div class="ticker-item"><span class="dot"></span> SP Disk per Node <span>1 TiB</span></div>
    <div class="ticker-item"><span class="dot"></span> Status <span class="up">Early Access</span></div>
    <div class="ticker-item"><span class="dot"></span> Uptime <span class="up">99.99%</span></div>
    <div class="ticker-item"><span class="dot"></span> Built by <span>Jump Trading × Aptos</span></div>
    <!-- duplicate for seamless loop -->
    <div class="ticker-item"><span class="dot"></span> Network <span class="up">shelbynet + testnet</span></div>
    <div class="ticker-item"><span class="dot"></span> Storage Providers <span class="up">16 active</span></div>
    <div class="ticker-item"><span class="dot"></span> Storage Capacity <span>~10 TiB</span></div>
    <div class="ticker-item"><span class="dot"></span> Aptos TPS <span class="up">30,000</span></div>
    <div class="ticker-item"><span class="dot"></span> Settlement Layer <span>Aptos Blockchain</span></div>
    <div class="ticker-item"><span class="dot"></span> SP Disk per Node <span>1 TiB</span></div>
    <div class="ticker-item"><span class="dot"></span> Status <span class="up">Early Access</span></div>
    <div class="ticker-item"><span class="dot"></span> Uptime <span class="up">99.99%</span></div>
    <div class="ticker-item"><span class="dot"></span> Built by <span>Jump Trading × Aptos</span></div>
  </div>
</div>

<!-- ECOSYSTEM -->
<section class="ecosystem" id="ecosystem">
  <div class="section-header reveal">
    <span class="section-label">// Core Modules</span>
    <h2 class="section-title">Ecosystem Infrastructure</h2>
    <p class="section-sub">Six foundational pillars powering the Shelby Network stack.</p>
  </div>

  <div class="modules-grid">

    <div class="module-card reveal">
      <span class="card-num">01</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="5" width="20" height="14" rx="2"/>
          <path d="M2 10h20"/>
          <path d="M6 15h4"/>
          <circle cx="17" cy="15" r="1.5"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby Wallet</h3>
      <p class="card-desc">Secure digital wallet for Shelby assets. Multi-chain support with hardware wallet integration and MPC key management.</p>
      <button class="card-btn">View Demo <span class="arrow">→</span></button>
    </div>

    <a class="module-card reveal reveal-delay-1" href="https://ferize585.github.io/explorer/" target="_blank" rel="noopener noreferrer" style="display:block;text-decoration:none;color:inherit;">
      <span class="card-num">02</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
          <path d="M11 8v6M8 11h6"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby Explorer</h3>
      <p class="card-desc">Explore network transactions and activity in real-time. Deep analytics, contract verification, and address tracking.</p>
      <span class="card-btn">Launch Explorer <span class="arrow">→</span></span>
    </a>

    <div class="module-card reveal reveal-delay-2">
      <span class="card-num">03</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="8" height="8" rx="1"/>
          <rect x="14" y="2" width="8" height="8" rx="1"/>
          <rect x="2" y="14" width="8" height="8" rx="1"/>
          <path d="M14 17h2a2 2 0 0 1 2 2v1M20 14h-2a2 2 0 0 0-2 2v1"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby Node</h3>
      <p class="card-desc">Run and manage Shelby network nodes. One-click deployment, automated rewards, and live performance dashboards.</p>
      <button class="card-btn">View Demo <span class="arrow">→</span></button>
    </div>

    <div class="module-card reveal">
      <span class="card-num">04</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 10 10"/>
          <path d="M22 2 12 12"/>
          <path d="m15 2 7 7"/>
          <path d="M22 9V2h-7"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby AI</h3>
      <p class="card-desc">AI-powered services inside the Shelby ecosystem. On-chain inference, autonomous agents, and smart contract auditing.</p>
      <button class="card-btn">View Demo <span class="arrow">→</span></button>
    </div>

    <div class="module-card reveal reveal-delay-1">
      <span class="card-num">05</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
          <path d="M13 14v-4M11 14v-4"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby Cloud</h3>
      <p class="card-desc">Decentralized cloud infrastructure. Edge compute, distributed storage, and permissionless hosting with 99.9% uptime SLA.</p>
      <button class="card-btn">View Demo <span class="arrow">→</span></button>
    </div>

    <div class="module-card reveal reveal-delay-2">
      <span class="card-num">06</span>
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
      <h3 class="card-title">Shelby Marketplace</h3>
      <p class="card-desc">Marketplace for apps and services. Discover, deploy, and monetize dApps across the Shelby ecosystem.</p>
      <button class="card-btn">View Demo <span class="arrow">→</span></button>
    </div>

  </div>
</section>

<!-- STATS -->
<section class="stats" id="stats">
  <div class="section-header reveal">
    <span class="section-label">// Protocol Data — sourced from docs.shelby.xyz</span>
    <h2 class="section-title">Network Statistics</h2>
    <p class="section-sub">Live metrics from the Shelby Protocol. Currently running on <strong style="color:var(--cyan)">shelbynet</strong> (devnet) and <strong style="color:var(--cyan)">testnet</strong>.</p>
  </div>

  <!-- network badges -->
  <div class="network-badges reveal" style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:2.5rem;">
    <div class="net-badge">
      <span class="badge-dot"></span>
      <span class="badge-name">shelbynet</span>
      <span class="badge-note">~10 TiB · resets weekly</span>
    </div>
    <div class="net-badge">
      <span class="badge-dot" style="background:var(--teal)"></span>
      <span class="badge-name">testnet</span>
      <span class="badge-note">Aptos testnet · persistent</span>
    </div>
  </div>

  <div class="stats-wrap reveal">

    <div class="stat-item">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8"><rect x="2" y="2" width="20" height="8" rx="1"/><rect x="2" y="14" width="20" height="8" rx="1"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
      </div>
      <div class="stat-num" data-target="16" data-suffix="">0</div>
      <div class="stat-label">Storage Providers</div>
      <div class="stat-sublabel">shelbynet · single region cloud</div>
      <div class="stat-bar"><div class="stat-bar-fill" data-width="0.55"></div></div>
    </div>

    <div class="stat-item">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      </div>
      <div class="stat-num" data-target="10" data-suffix=" TiB">0</div>
      <div class="stat-label">Storage Capacity</div>
      <div class="stat-sublabel">16 SPs × 1 TiB each</div>
      <div class="stat-bar"><div class="stat-bar-fill" data-width="0.4"></div></div>
    </div>

    <div class="stat-item">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8"><polyline points="13 2 13 9 22 9"/><path d="M11 22H5a2 2 0 0 1-2-2V7l7-5 9 6.3V13"/><path d="M16 19h6M19 16v6"/></svg>
      </div>
      <div class="stat-num" data-target="30000" data-suffix="">0</div>
      <div class="stat-label">Aptos Peak TPS</div>
      <div class="stat-sublabel">settlement layer throughput</div>
      <div class="stat-bar"><div class="stat-bar-fill" data-width="1.0"></div></div>
    </div>

    <div class="stat-item">
      <div class="stat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#63d2ff" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div class="stat-num" data-target="2" data-suffix="">0</div>
      <div class="stat-label">Active Networks</div>
      <div class="stat-sublabel">shelbynet + testnet</div>
      <div class="stat-bar"><div class="stat-bar-fill" data-width="0.3"></div></div>
    </div>

  </div>

  <!-- tech stack info row -->
  <div class="stack-row reveal" style="margin-top:1.5px;background:var(--surface);border:1px solid var(--border);border-top:none;border-radius:0 0 6px 6px;padding:1.4rem 2.5rem;display:flex;flex-wrap:wrap;gap:2rem;align-items:center;justify-content:center;">
    <div class="stack-item">
      <span class="stack-key">Coordination Layer</span>
      <span class="stack-val">Aptos Blockchain (BFT)</span>
    </div>
    <div class="stack-divider"></div>
    <div class="stack-item">
      <span class="stack-key">Data Integrity</span>
      <span class="stack-val">Erasure Coding + Novel Audit</span>
    </div>
    <div class="stack-divider"></div>
    <div class="stack-item">
      <span class="stack-key">Bandwidth</span>
      <span class="stack-val">Dedicated Fiber Network (Geomi)</span>
    </div>
    <div class="stack-divider"></div>
    <div class="stack-item">
      <span class="stack-key">Built by</span>
      <span class="stack-val">Jump Trading Group × Aptos</span>
    </div>
  </div>

</section>

<!-- FOOTER -->
<footer>
  <div class="footer-left">
    <a href="https://shelby.xyz" style="display:inline-flex;align-items:center;flex-shrink:0;"><img
      src="data:image/jpeg;base64,"
      alt="Shelby Network"
      class="footer-logo-img"
      width="38"
      height="38"
    /></a>
    <span class="footer-copy">© 2026 Shelby Network. All rights reserved.</span>
  </div>
  <div class="footer-links">
    <a href="https://docs.shelby.xyz/protocol" target="_blank">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Docs
    </a>
    <a href="https://github.com/shelby" target="_blank">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      GitHub
    </a>
    <a href="https://discord.com/invite/shelbyserves" target="_blank">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Community
    </a>
    <a href="https://explorer.shelby.xyz/testnet" target="_blank">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      Explorer
    </a>
    <a href="https://x.com/shelbyserves" target="_blank" rel="noopener noreferrer">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l16 16M4 20L20 4"/></svg>
      X
    </a>
  </div>
</footer>

<script>
  /* Cursor */
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
  function animCursor() {
    cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
    rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
    requestAnimationFrame(animCursor);
  }
  animCursor();

  /* Network Canvas */
  const canvas = document.getElementById('networkCanvas');
  const ctx = canvas.getContext('2d');
  function resizeCanvas() {
    canvas.width = canvas.offsetWidth * window.devicePixelRatio;
    canvas.height = 200 * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }
  resizeCanvas();

  const W = () => canvas.offsetWidth, H = 200;
  const nodes = Array.from({length: 22}, () => ({
    x: Math.random() * W(), y: Math.random() * H,
    vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
    r: Math.random() * 2.5 + 1.5,
    pulse: Math.random() * Math.PI * 2
  }));

  function drawNetwork(ts) {
    ctx.clearRect(0,0,W(),H);
    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy;
      if(n.x < 0 || n.x > W()) n.vx *= -1;
      if(n.y < 0 || n.y > H) n.vy *= -1;
      n.pulse += 0.03;
    });
    // edges
    nodes.forEach((a, i) => {
      nodes.slice(i+1).forEach(b => {
        const d = Math.hypot(a.x-b.x, a.y-b.y);
        if(d < 140) {
          ctx.beginPath();
          ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
          ctx.strokeStyle = `rgba(99,210,255,${(1-d/140)*0.25})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      });
    });
    // nodes
    nodes.forEach(n => {
      const pulse = Math.sin(n.pulse) * 0.4 + 0.6;
      const grd = ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*4);
      grd.addColorStop(0,'rgba(99,210,255,0.9)');
      grd.addColorStop(1,'rgba(99,210,255,0)');
      ctx.beginPath();
      ctx.arc(n.x,n.y,n.r*4*pulse,0,Math.PI*2);
      ctx.fillStyle = grd; ctx.fill();
      ctx.beginPath();
      ctx.arc(n.x,n.y,n.r,0,Math.PI*2);
      ctx.fillStyle = '#63d2ff'; ctx.fill();
    });
    requestAnimationFrame(drawNetwork);
  }
  requestAnimationFrame(drawNetwork);
  window.addEventListener('resize', resizeCanvas);

  /* Scroll Reveal */
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  reveals.forEach(r => observer.observe(r));

  /* Counter Animation */
  function animateCounter(el) {
    const target = +el.dataset.target;
    const suffix = el.dataset.suffix || '';
    const duration = 1800;
    const start = performance.now();
    function step(now) {
      const t = Math.min((now-start)/duration,1);
      const ease = 1 - Math.pow(1-t,3);
      el.textContent = Math.round(ease*target).toLocaleString() + suffix;
      if(t < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  const statsObserver = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if(e.isIntersecting) {
        e.target.querySelectorAll('.stat-num').forEach(animateCounter);
        e.target.querySelectorAll('.stat-bar-fill').forEach(bar => {
          setTimeout(() => bar.classList.add('animated'), 200);
        });
        statsObserver.unobserve(e.target);
      }
    });
  }, {threshold: 0.3});
  document.querySelectorAll('.stats-wrap').forEach(s => statsObserver.observe(s));

  /* Smooth scroll */
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if(target) { e.preventDefault(); target.scrollIntoView({behavior:'smooth',block:'start'}); }
    });
  });

  /* ---- NETWORK DROPDOWN ---- */
  const trigger  = document.getElementById('networkTrigger');
  const menu     = document.getElementById('networkMenu');
  const wrap     = document.getElementById('networkDropdown');
  let closeTimer = null;

  function openDropdown() {
    clearTimeout(closeTimer);
    menu.classList.add('open');
    trigger.classList.add('open');
    trigger.setAttribute('aria-expanded', 'true');
  }
  function closeDropdown() {
    closeTimer = setTimeout(() => {
      menu.classList.remove('open');
      trigger.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    }, 120);
  }

  // Hover: open on enter, close with delay on leave
  wrap.addEventListener('mouseenter', openDropdown);
  wrap.addEventListener('mouseleave', closeDropdown);

  // Click: toggle (useful on touch / keyboard)
  trigger.addEventListener('click', e => {
    e.stopPropagation();
    menu.classList.contains('open') ? closeDropdown() : openDropdown();
  });

  // Close on outside click
  document.addEventListener('click', e => {
    if (!wrap.contains(e.target)) closeDropdown();
  });

  // Keyboard: Escape closes
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeDropdown(); closeDevDropdown(); }
  });

  /* ---- DEVELOPERS DROPDOWN ---- */
  const devTrigger  = document.getElementById('devTrigger');
  const devMenu     = document.getElementById('devMenu');
  const devWrap     = document.getElementById('devDropdown');
  let devCloseTimer = null;

  function openDevDropdown() {
    clearTimeout(devCloseTimer);
    devMenu.classList.add('open');
    devTrigger.classList.add('open');
    devTrigger.setAttribute('aria-expanded', 'true');
  }
  function closeDevDropdown() {
    devCloseTimer = setTimeout(() => {
      devMenu.classList.remove('open');
      devTrigger.classList.remove('open');
      devTrigger.setAttribute('aria-expanded', 'false');
    }, 120);
  }

  devWrap.addEventListener('mouseenter', openDevDropdown);
  devWrap.addEventListener('mouseleave', closeDevDropdown);

  devTrigger.addEventListener('click', e => {
    e.stopPropagation();
    devMenu.classList.contains('open') ? closeDevDropdown() : openDevDropdown();
  });

  document.addEventListener('click', e => {
    if (!devWrap.contains(e.target)) closeDevDropdown();
  });
</script>
</body>
</html>
